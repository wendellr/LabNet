# BGP Lab Platform — variáveis para Portainer Stack
#
# No Portainer:
#   Stacks -> Add stack -> Repository -> Environment variables
# Cadastre estes nomes/valores na tela da stack.

# Portas públicas do Nginx
HTTP_PORT=80
HTTPS_PORT=443

# Porta direta do backend. Pode manter fechada no firewall e usar só o Nginx.
BACKEND_PORT=3000
PORT=3000

# Diretório absoluto no host Linux usado pelo ContainerLab e pelos binds FRR.
# Crie no servidor antes do deploy:
#   sudo mkdir -p /opt/bgp-labs
LAB_HOST_BASE_DIR=/opt/bgp-labs

# Docker socket do host
DOCKER_SOCKET=/var/run/docker.sock

# FRR mais recente
FRR_IMAGE=frrouting/frr:latest

# Painel do professor
TEACHER_PASSWORD=troque-esta-senha

# Email de resultados via Resend, opcional
TEACHER_EMAIL=
RESEND_API_KEY=
