# BGP Lab Platform — variáveis para Portainer Stack
#
# No Portainer:
#   Stacks -> Add stack -> Repository -> Environment variables
# Cadastre estes nomes/valores na tela da stack.

# Porta local do frontend usada pelo Nginx do host.
# Mantemos em 127.0.0.1 para nao expor o container direto na internet.
HTTP_BIND=127.0.0.1
HTTP_PORT=8088

# O backend/provisioner roda no host via systemd, nao nesta stack.
# Configure HOST/PORT/FRR_IMAGE/TEACHER_* no arquivo:
#   /opt/labnet/backend/.env
