# BGP Lab Platform — variáveis para Portainer Stack
#
# No Portainer:
#   Stacks -> Add stack -> Repository -> Environment variables
# Cadastre estes nomes/valores na tela da stack.

# Porta local do frontend usada pelo Nginx do host.
# Mantemos em 127.0.0.1 para nao expor o container direto na internet.
HTTP_BIND=127.0.0.1
HTTP_PORT=8088

# Porta local do backend usada pelo Nginx do host para /api, /ws e /graph.
BACKEND_BIND=127.0.0.1
PORT=3000

# Diretório absoluto no host Linux usado pelo ContainerLab e pelos binds FRR.
# Crie no servidor antes do deploy:
#   sudo mkdir -p /opt/bgp-labs
LAB_HOST_BASE_DIR=/opt/bgp-labs

# Docker socket do host
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_NETNS_DIR=/run/docker/netns
HOST_NETNS_DIR=/run/netns

# FRR mais recente
FRR_IMAGE=quay.io/frrouting/frr:10.5.0

# Painel do professor
TEACHER_PASSWORD=troque-esta-senha

# Email de resultados via Resend, opcional
TEACHER_EMAIL=
RESEND_API_KEY=
