# BGP Lab Platform — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env

# ── Autenticação do Professor ─────────────────────────────────────────────────
# Senha usada na tela de login do painel do professor
TEACHER_PASSWORD=bgp@teach2025

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Obtenha sua API Key em https://resend.com → API Keys
# O plano gratuito permite 3.000 emails/mês
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email de destino para receber os resultados dos alunos
TEACHER_EMAIL=professor@escola.com.br

# ── Servidor ──────────────────────────────────────────────────────────────────
# Porta do backend Node.js (padrão: 3000)
PORT=3000

# Diretório base para armazenar arquivos de sessão ContainerLab
LAB_BASE_DIR=/opt/bgp-labs
