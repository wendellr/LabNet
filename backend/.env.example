# BGP Lab Platform — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env

# ── Autenticação do Professor ─────────────────────────────────────────────────
# Senha usada na tela de login do painel do professor
TEACHER_PASSWORD=bgp@teach2025

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Obtenha sua API Key em https://resend.com → API Keys
# O plano gratuito permite 3.000 emails/mês
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Remetente usado pela Resend. Em produção, prefira um domínio verificado.
RESEND_FROM=onboarding@resend.dev

# Email de destino para receber os resultados dos alunos
TEACHER_EMAIL=professor@escola.com.br

# ── Servidor ──────────────────────────────────────────────────────────────────
# Porta do backend Node.js (padrão: 3000)
HOST=127.0.0.1
PORT=3000

# Diretório absoluto no host Linux para armazenar sessões ContainerLab.
# Em deploy Docker/Portainer, mantenha LAB_HOST_BASE_DIR e LAB_BASE_DIR iguais.
LAB_BASE_DIR=/opt/bgp-labs
LAB_HOST_BASE_DIR=/opt/bgp-labs

# Imagem FRR usada pelos roteadores dos labs
FRR_IMAGE=quay.io/frrouting/frr:10.5.0
